<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profil" android:textSize="24sp" android:textStyle="bold"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Score de la semaine" android:layout_marginTop="10dp"/>
        <TextView android:id="@+id/profileScore" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0%" android:textSize="32sp" android:textStyle="bold"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Paramètres" android:layout_marginTop="18dp" android:textStyle="bold"/>
        <TextView android:id="@+id/profileGrace" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Grace days: 2"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Stockage: local uniquement"/>
    </LinearLayout>
</ScrollView>
