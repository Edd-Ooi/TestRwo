<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mon Jardin" android:textSize="24sp" android:textStyle="bold"/>
        <TextView android:id="@+id/gardenSummary" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="0 jours cumulés"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:orientation="horizontal">
            <TextView android:id="@+id/gardenStreak" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Streak: 0"/>
            <TextView android:id="@+id/gardenMonth" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Ce mois: 0"/>
            <TextView android:id="@+id/gardenRate" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Taux: 0%"/>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:text="Heatmap 28 jours" android:textStyle="bold"/>
        <GridLayout
            android:id="@+id/gardenHeatmap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="7"
            android:layout_marginTop="8dp"/>

        <TextView android:id="@+id/gardenQuote" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:background="#E8F7EE" android:padding="12dp" android:textStyle="italic" android:text="\"Reviens. C'est tout ce qu'on demande.\""/>
    </LinearLayout>
</ScrollView>
